# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#               🤖 TELEGRAM BOT CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Telegram Bot Token (Get from @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890

# Your Telegram User ID (Get from @userinfobot)
OWNER_ID=123456789

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#               🗄️ LEAK OSINT API CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# LeakOSINT API URL
API_URL=https://leakosintapi.com/

# Your API Token (Get from LeakOSINT dashboard)
API_TOKEN=your_api_token_here

# API Language (en/ru/etc)
API_LANG=en

# Result Limit per Query
API_LIMIT=300

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#               💾 SUPABASE DATABASE CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Supabase Project URL (From your Supabase project settings)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co

# Supabase API Key (anon/public key from project settings → API)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN2...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#               📢 REQUIRED CHANNELS (OPTIONAL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Initial required channels (comma-separated, with @ or channel ID)
# You can add more via /addchannel command
# Examples:
#   - Public channel: @mychannel
#   - Private channel: -1001234567890
#   - Multiple: @channel1,@channel2,-1001234567890

REQUIRED_CHANNELS=@yourchannel1,@yourchannel2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#               ⚙️ OPTIONAL SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Bot Timezone (default: UTC)
# TIMEZONE=Asia/Kolkata

# Polling Timeout (seconds)
# POLLING_TIMEOUT=60

# Debug Mode (true/false)
# DEBUG=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#               📝 NOTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env to GitHub (use .gitignore)
# 3. Get Bot Token: https://t.me/BotFather
# 4. Get User ID: https://t.me/userinfobot
# 5. Get Supabase credentials: https://app.supabase.com
# 6. Make sure bot is admin in all required channels
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
